{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../../",
    "resolveJsonModule": true,
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../../apps/api/src/**/*.ts",
    "../../apps/api/src/**/*.json"
  ],
  "exclude": [
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs",
    "../../apps/api/src/**/*.spec.ts",
    "../../apps/api/src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../api/tsconfig.app.json"
    },
    {
      "path": "../../libs/shared/tsconfig.lib.json"
    }
  ]
}
