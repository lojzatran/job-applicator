{
  "name": "@apps/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env-utils": {
      "import": "./src/lib/utils/env-utils.ts",
      "default": "./src/lib/utils/env-utils.ts"
    },
    "./env": {
      "import": "./src/lib/utils/env.ts",
      "default": "./src/lib/utils/env.ts"
    },
    "./pinoLogger": {
      "import": "./src/lib/logger/pinoLogger.ts",
      "default": "./src/lib/logger/pinoLogger.ts"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1"
  }
}
